# Copy to .env.local and fill in. Never commit real secrets.

# ── Supabase ──────────────────────────────────────────────────────────────
# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (Drizzle) ────────────────────────────────────────────────────
# From Supabase → Project Settings → Database → Connection string
# DATABASE_URL: pooled connection (port 6543) for the app at runtime.
# DIRECT_URL:   direct connection (port 5432) used by drizzle-kit migrations.
DATABASE_URL=
DIRECT_URL=

# ── AI copilot ────────────────────────────────────────────────────────────
# Leave AI_PROVIDER=mock to use the built-in deterministic mock (no key needed).
# Switch to "anthropic" or "openai" once a key is provided.
AI_PROVIDER=mock
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Stripe (test mode — billing milestone) ────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PRICE_PRO=

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
